# Docker file for Raspberry Pi 4 with Raspberry Pi Touch Display 2
# Uses direct framebuffer access - no pygame/SDL required
FROM python:3.13-slim

WORKDIR /app/cpython
COPY Ae.Pico/cpython/requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

COPY Ae.Pico /app
CMD ["python3", "-u", "main.py"]
